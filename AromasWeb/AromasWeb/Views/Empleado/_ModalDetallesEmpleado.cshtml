<div class="modal fade admin-modal modal-olive" id="modalDetallesEmpleado" tabindex="-1" aria-labelledby="modalDetallesEmpleadoLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <!-- Header -->
            <div class="modal-header">
                <h5 class="modal-title" id="modalDetallesEmpleadoLabel">
                    <div class="modal-icon">
                        <i class="fas fa-user-tie"></i>
                    </div>
                    Detalles del Empleado
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <!-- Body -->
            <div class="modal-body">

                <!-- Nombre + Cargo como meta -->
                <div class="modal-entity-header entity-block">
                    <h5 id="detalles-nombre-empleado" class="modal-entity-name"></h5>
                    <div class="modal-entity-meta">
                        <div class="modal-entity-meta-item">
                            <small><i class="fas fa-briefcase"></i> Cargo:</small>
                            <p id="detalles-cargo-empleado"></p>
                        </div>
                        <div class="modal-entity-meta-item" id="detalles-empleado-antiguo" style="display:none;">
                            <small><i class="fas fa-award"></i></small>
                            <p>Empleado Antiguo</p>
                        </div>
                    </div>
                </div>

                <!-- Rol y Estado -->
                <div class="modal-data-grid-2">
                    <div class="modal-data-cell">
                        <label class="modal-data-label">
                            <i class="fas fa-user-tag"></i> Rol
                        </label>
                        <span id="detalles-rol-empleado" class="badge" style="font-size: 0.95rem; padding: 0.4rem 1.2rem; border-radius: 50px; font-weight: 600; display: inline-block;"></span>
                    </div>
                    <div class="modal-data-cell">
                        <label class="modal-data-label">
                            <i class="fas fa-toggle-on"></i> Estado
                        </label>
                        <span id="detalles-estado-badge-empleado" class="badge" style="font-size: 0.95rem; padding: 0.4rem 1.2rem; border-radius: 50px; font-weight: 600; display: inline-block;"></span>
                    </div>
                </div>

                <!-- Información Personal -->
                <h6 class="modal-subsection-title">
                    <i class="fas fa-user"></i> Información Personal
                </h6>
                <div class="modal-data-grid-3">
                    <div class="modal-data-cell">
                        <label class="modal-data-label">
                            <i class="fas fa-id-card"></i> Identificación
                        </label>
                        <p id="detalles-identificacion-empleado" class="modal-data-value"></p>
                    </div>
                    <div class="modal-data-cell">
                        <label class="modal-data-label">
                            <i class="fas fa-phone"></i> Teléfono
                        </label>
                        <p id="detalles-telefono-empleado" class="modal-data-value"></p>
                    </div>
                    <div class="modal-data-cell">
                        <label class="modal-data-label">
                            <i class="fas fa-envelope"></i> Correo Electrónico
                        </label>
                        <p id="detalles-correo-empleado" class="modal-data-value" style="word-break: break-all;"></p>
                    </div>
                </div>

                <!-- Contratación -->
                <h6 class="modal-subsection-title">
                    <i class="fas fa-calendar-alt"></i> Información de Contratación
                </h6>
                <div class="modal-data-grid-2">
                    <div class="modal-data-cell">
                        <label class="modal-data-label">
                            <i class="fas fa-calendar-check"></i> Fecha de Contratación
                        </label>
                        <p id="detalles-fechacontratacion-empleado" class="modal-data-value"></p>
                    </div>
                    <div class="modal-data-cell">
                        <label class="modal-data-label">
                            <i class="fas fa-hourglass-half"></i> Antigüedad
                        </label>
                        <p id="detalles-antiguedad-empleado" class="modal-data-value"></p>
                    </div>
                </div>

                <!-- Emergencia -->
                <h6 class="modal-subsection-title">
                    <i class="fas fa-notes-medical"></i> Información de Emergencia
                </h6>
                <div class="modal-summary">
                    <div class="modal-summary-grid">
                        <div>
                            <label class="modal-summary-label">
                                <i class="fas fa-phone-square"></i> Contacto de Emergencia
                            </label>
                            <p id="detalles-contactoemergencia-empleado" class="modal-summary-value"></p>
                        </div>
                        <div>
                            <label class="modal-summary-label">
                                <i class="fas fa-allergies"></i> Alergias
                            </label>
                            <p id="detalles-alergias-empleado" class="modal-summary-value"></p>
                        </div>
                        <div>
                            <label class="modal-summary-label">
                                <i class="fas fa-pills"></i> Medicamentos
                            </label>
                            <p id="detalles-medicamentos-empleado" class="modal-summary-value"></p>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Footer -->
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <span><i class="fas fa-times"></i> Cerrar</span>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const botonesDetalles = document.querySelectorAll('.btn-detalles');

        botonesDetalles.forEach(boton => {
            boton.addEventListener('click', function () {
                const nombre             = this.getAttribute('data-nombre');
                const apellidos          = this.getAttribute('data-apellidos');
                const identificacion     = this.getAttribute('data-identificacion');
                const correo             = this.getAttribute('data-correo');
                const telefono           = this.getAttribute('data-telefono');
                const cargo              = this.getAttribute('data-cargo');
                const rol                = this.getAttribute('data-rol');
                const fechaContratacion  = this.getAttribute('data-fechacontratacion');
                const antiguedad         = this.getAttribute('data-antiguedad');
                const estado             = this.getAttribute('data-estado');
                const esAntiguo          = this.getAttribute('data-esantiguo') === 'True';
                const contactoEmergencia = this.getAttribute('data-contactoemergencia');
                const alergias           = this.getAttribute('data-alergias');
                const medicamentos       = this.getAttribute('data-medicamentos');

                document.getElementById('detalles-nombre-empleado').textContent          = nombre + ' ' + apellidos;
                document.getElementById('detalles-cargo-empleado').textContent           = cargo;
                document.getElementById('detalles-identificacion-empleado').textContent  = identificacion;
                document.getElementById('detalles-correo-empleado').textContent          = correo;
                document.getElementById('detalles-telefono-empleado').textContent        = telefono;
                document.getElementById('detalles-fechacontratacion-empleado').textContent = fechaContratacion;
                document.getElementById('detalles-antiguedad-empleado').textContent      = antiguedad;

                const antiguoEl = document.getElementById('detalles-empleado-antiguo');
                if (antiguoEl) antiguoEl.style.display = esAntiguo ? 'flex' : 'none';

                const contactoEl = document.getElementById('detalles-contactoemergencia-empleado');
                contactoEl.textContent = contactoEmergencia || 'No especificado';
                contactoEl.style.opacity = contactoEmergencia ? '1' : '0.5';

                const alergiasEl = document.getElementById('detalles-alergias-empleado');
                alergiasEl.textContent = alergias || 'Ninguna alergia registrada';
                alergiasEl.style.opacity = alergias ? '1' : '0.5';

                const medicamentosEl = document.getElementById('detalles-medicamentos-empleado');
                medicamentosEl.textContent = medicamentos || 'Ningún medicamento registrado';
                medicamentosEl.style.opacity = medicamentos ? '1' : '0.5';

                const rolBadge = document.getElementById('detalles-rol-empleado');
                rolBadge.textContent = rol;
                rolBadge.style.background = rol === 'Administrador' ? 'var(--gold)' : 'var(--olive-green)';
                rolBadge.style.color = 'white';

                const estadoBadge = document.getElementById('detalles-estado-badge-empleado');
                estadoBadge.textContent = estado === 'Activo' ? 'Activo' : 'Inactivo';
                estadoBadge.style.background = estado === 'Activo' ? 'var(--green)' : 'var(--red)';
                estadoBadge.style.color = 'white';
            });
        });
    });
</script>