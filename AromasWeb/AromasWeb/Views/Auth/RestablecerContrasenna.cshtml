@{
    ViewBag.Title = "Restablecer Contraseña";
}

<!-- Hero Section -->
<section class="hero" style="min-height: 40vh; padding: 8rem 0 4rem;">
    <div class="hero-bg-overlay"></div>
    <div class="hero-leaves"></div>
    <div class="container hero-container" style="display: block;">
        <div class="hero-content" data-aos="fade-up" style="text-align: center;">
            <span class="hero-badge">
                <i class="fas fa-lock-open"></i>
                Nueva Contraseña
            </span>
            <h1 class="hero-title" style="font-size: 3.5rem;">
                Restablecer
                <span class="hero-title-accent">Contraseña</span>
            </h1>
            <p class="hero-subtitle">
                Crea una nueva contraseña segura para tu cuenta
            </p>
        </div>
    </div>
    <div class="scroll-indicator">
        <div class="mouse">
            <div class="wheel"></div>
        </div>
    </div>
</section>

<!-- Formulario Section -->
<section class="admin-form-section" style="background: var(--light-cream)">

    <!-- Enlace verificado -->
    <div class="admin-form-body" style="padding-bottom: 0;">
        <div class="admin-form-info-box" style="border-color: rgba(47,158,49,0.3); background: rgba(47,158,49,0.06);">
            <i class="fas fa-check-circle" style="color: var(--green);"></i>
            <div>
                <strong style="color: var(--green);">¡Enlace verificado!</strong>
                <p>Tu identidad ha sido confirmada. Ahora puedes establecer una nueva contraseña.</p>
            </div>
        </div>
    </div>

    <div class="container" style="max-width: 80%;">
        @using (Html.BeginForm("RestablecerContrasena", "Auth", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <div class="admin-form-wrapper" data-aos="fade-up">

                @Html.ValidationSummary(true, "Por favor, corrige los siguientes errores:", new { @class = "alert alert-danger" })

                <!-- Header -->
                <div class="admin-form-header">
                    <i class="fas fa-shield-alt"></i>
                    <h5>Nueva Contraseña</h5>
                </div>

                <div class="admin-form-body">

                    <!-- Nueva Contraseña -->
                    <div class="form-group">
                        <label>
                            <i class="fas fa-key"></i>
                            Nueva Contraseña
                        </label>
                        <div style="position: relative;">
                            <input type="password" name="NuevaContrasena" id="password-input" class="form-control" placeholder="Ingresa tu nueva contraseña" required />
                            <button type="button" id="toggle-password" style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); background: none; border: none; color: var(--charcoal); cursor: pointer; font-size: 1.1rem; opacity: 0.5;">
                                <i class="fas fa-eye" id="eye-icon"></i>
                            </button>
                        </div>
                        <!-- Barra de fortaleza -->
                        <div style="margin-top: 0.7rem;">
                            <div style="display: flex; gap: 0.3rem; height: 4px; margin-bottom: 0.4rem;">
                                <div id="strength-1" style="flex: 1; background: rgba(143,142,106,0.2); border-radius: 2px; transition: all 0.3s;"></div>
                                <div id="strength-2" style="flex: 1; background: rgba(143,142,106,0.2); border-radius: 2px; transition: all 0.3s;"></div>
                                <div id="strength-3" style="flex: 1; background: rgba(143,142,106,0.2); border-radius: 2px; transition: all 0.3s;"></div>
                                <div id="strength-4" style="flex: 1; background: rgba(143,142,106,0.2); border-radius: 2px; transition: all 0.3s;"></div>
                            </div>
                            <small id="strength-text" style="color: var(--charcoal); opacity: 0.7; font-size: 0.85rem;"></small>
                        </div>
                    </div>

                    <!-- Confirmar Contraseña -->
                    <div class="form-group">
                        <label>
                            <i class="fas fa-check-circle"></i>
                            Confirmar Nueva Contraseña
                        </label>
                        <div style="position: relative;">
                            <input type="password" name="ConfirmarNuevaContrasena" id="confirm-password-input" class="form-control" placeholder="Confirma tu nueva contraseña" required />
                            <button type="button" id="toggle-confirm-password" style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); background: none; border: none; color: var(--charcoal); cursor: pointer; font-size: 1.1rem; opacity: 0.5;">
                                <i class="fas fa-eye" id="eye-icon-confirm"></i>
                            </button>
                        </div>
                        <div id="password-match-message" style="margin-top: 0.4rem;"></div>
                    </div>

                    <!-- Requisitos de contraseña — lista real -->
                    <div>
                        <label style="font-weight: 600; color: var(--dark-green); display: flex; align-items: center; gap: 0.6rem; font-family: var(--font-primary); margin-bottom: 0.8rem;">
                            <i class="fas fa-list-check" style="color: var(--gold);"></i>
                            Requisitos de seguridad
                        </label>
                        <ul style="list-style: none; padding: 0; margin: 0; display: grid; gap: 0.45rem;">
                            <li id="req-length" style="display: flex; align-items: center; gap: 0.7rem; font-size: 0.92rem; color: var(--charcoal); opacity: 0.75; transition: all 0.3s;">
                                <i class="fas fa-circle" style="font-size: 0.45rem; flex-shrink: 0;"></i>
                                Mínimo 8 caracteres
                            </li>
                            <li id="req-uppercase" style="display: flex; align-items: center; gap: 0.7rem; font-size: 0.92rem; color: var(--charcoal); opacity: 0.75; transition: all 0.3s;">
                                <i class="fas fa-circle" style="font-size: 0.45rem; flex-shrink: 0;"></i>
                                Al menos una letra mayúscula (A-Z)
                            </li>
                            <li id="req-lowercase" style="display: flex; align-items: center; gap: 0.7rem; font-size: 0.92rem; color: var(--charcoal); opacity: 0.75; transition: all 0.3s;">
                                <i class="fas fa-circle" style="font-size: 0.45rem; flex-shrink: 0;"></i>
                                Al menos una letra minúscula (a-z)
                            </li>
                            <li id="req-number" style="display: flex; align-items: center; gap: 0.7rem; font-size: 0.92rem; color: var(--charcoal); opacity: 0.75; transition: all 0.3s;">
                                <i class="fas fa-circle" style="font-size: 0.45rem; flex-shrink: 0;"></i>
                                Al menos un número (0-9)
                            </li>
                        </ul>
                    </div>

                    <!-- Consejos de seguridad -->
                    <div class="admin-form-info-box" style="border-color: rgba(184,167,106,0.4);">
                        <i class="fas fa-shield-alt" style="color: var(--gold-bright);"></i>
                        <div>
                            <strong>Consejos de seguridad</strong>
                            <ul style="margin: 0.4rem 0 0; padding-left: 1.2rem; line-height: 1.8;">
                                <li>No uses información personal (nombre, fecha de nacimiento)</li>
                                <li>Evita contraseñas que hayas usado antes</li>
                                <li>No compartas tu contraseña con nadie</li>
                                <li>Usa una contraseña diferente para cada sitio</li>
                            </ul>
                        </div>
                    </div>

                </div>

                <!-- Footer -->
                <div class="admin-form-footer">
                    <button type="button" class="btn btn-secondary" onclick="window.location.href='@Url.Action("Login", "Auth")'">
                        <i class="fas fa-arrow-left"></i>
                        <span>Cancelar</span>
                    </button>
                    <button type="button" id="btn-restablecer" class="btn btn-primary btn-3d" style="flex: 2;">
                        <i class="fas fa-check"></i>
                        <span>Restablecer Contraseña</span>
                    </button>
                </div>

            </div>
        }
    </div>
</section>

<!-- Features Section -->
<section class="features" style="padding: 4rem 0;">
    <div class="container">
        <div class="features-grid">
            <div class="feature-card" data-aos="fade-up" data-aos-delay="0">
                <div class="feature-icon"><i class="fas fa-lock"></i></div>
                <h3>Seguridad Total</h3>
                <p>Tu contraseña se encripta con los más altos estándares</p>
            </div>
            <div class="feature-card" data-aos="fade-up" data-aos-delay="100">
                <div class="feature-icon"><i class="fas fa-history"></i></div>
                <h3>Cambios Registrados</h3>
                <p>Recibirás un correo de confirmación del cambio</p>
            </div>
            <div class="feature-card" data-aos="fade-up" data-aos-delay="200">
                <div class="feature-icon"><i class="fas fa-bell"></i></div>
                <h3>Alertas Activas</h3>
                <p>Te notificaremos si detectamos actividad sospechosa</p>
            </div>
            <div class="feature-card" data-aos="fade-up" data-aos-delay="300">
                <div class="feature-icon"><i class="fas fa-headset"></i></div>
                <h3>Soporte 24/7</h3>
                <p>Estamos aquí para ayudarte en todo momento</p>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/js/recuperarContrasenna.js"></script>
}