@{
    ViewBag.Title = "Recuperar Contraseña";
}

<section class="login-hero registro-hero">
    <div class="login-card registro-card">

        @if (TempData["Mensaje"] != null)
        {
            <div style="padding: 1.5rem 2.5rem 0;">
                <div class="login-error-box" style="background: rgba(47,158,49,0.05); border-color: rgba(47,158,49,0.3);">
                    <i class="fas fa-check-circle" style="color: var(--green);"></i>
                    <div>
                        <strong style="color: var(--green);">¡Código enviado!</strong>
                        <p>@TempData["Mensaje"]</p>
                    </div>
                </div>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div style="padding: 1.5rem 2.5rem 0;">
                <div class="login-error-box">
                    <i class="fas fa-exclamation-circle"></i>
                    <div>
                        <strong>Error</strong>
                        <p>@TempData["Error"]</p>
                    </div>
                </div>
            </div>
        }

        <div class="login-card-inner">

            <div class="login-card-heading">
                <h2>¿Olvidaste tu Contraseña?</h2>
                <p>Te enviaremos un código para recuperar tu cuenta</p>
            </div>

            @using (Html.BeginForm("OlvideContrasenna", "Auth", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "Por favor, corrige los siguientes errores:", new { @class = "alert alert-danger" })

                <!-- ¿Cómo funciona? -->
                <div class="admin-form-info-box" style="margin-bottom: 1.2rem;">
                    <i class="fas fa-envelope"></i>
                    <div>
                        <strong>¿Cómo funciona?</strong>
                        <p>Ingresa tu correo y te enviaremos un código de 6 dígitos para restablecer tu contraseña. El código será válido por <strong>15 minutos</strong>.</p>
                    </div>
                </div>

                <!-- Correo -->
                <div class="form-group" style="margin-bottom: 1.2rem;">
                    <label><i class="fas fa-envelope"></i> Correo Electrónico Registrado</label>
                    <input type="email" name="correo" class="form-control" placeholder="correo@ejemplo.com" required autofocus />
                    <small class="admin-form-hint">
                        <i class="fas fa-info-circle"></i>
                        Ingresa el correo con el que te registraste
                    </small>
                </div>

                <!-- Advertencia -->
                <div class="admin-form-info-box" style="border-color: rgba(184,167,106,0.4); margin-bottom: 1.5rem;">
                    <i class="fas fa-exclamation-triangle" style="color: var(--gold-bright);"></i>
                    <div>
                        <strong>Importante</strong>
                        <ul style="margin: 0.4rem 0 0; padding-left: 1.2rem; line-height: 1.8;">
                            <li>El código de recuperación expira en 15 minutos</li>
                            <li>Solo puedes usar el código una vez</li>
                            <li>Si no recibes el correo en 5 minutos, revisa spam</li>
                        </ul>
                    </div>
                </div>

                <!-- Botones -->
                <div class="admin-form-footer" style="padding: 1.2rem 0 0; background: transparent; border-top: 1px solid rgba(143,142,106,0.12);">
                    <button type="button" class="btn btn-secondary" onclick="window.location.href='@Url.Action("Login", "Auth")'">
                        <i class="fas fa-arrow-left"></i>
                        <span>Volver al Login</span>
                    </button>
                    <button type="submit" class="btn btn-primary btn-3d">
                        <i class="fas fa-paper-plane"></i>
                        <span>Enviar Código</span>
                    </button>
                </div>
            }

            <!-- Pasos a seguir -->
            <div style="margin-top: 2rem; padding-top: 1.8rem; border-top: 1px solid rgba(143,142,106,0.12);">
                <div class="admin-form-header" style="margin-bottom: 1.2rem; border-radius: 12px;">
                    <i class="fas fa-list-ol"></i>
                    <h5>Pasos a seguir</h5>
                </div>
                <div style="display: grid; gap: 0.8rem;">
                    @{
                        var pasos = new[] {
                            new { num = "1", bg = "var(--dark-green)", icon = "fa-keyboard",   titulo = "Ingresa tu correo",          desc = "Escribe el correo electrónico asociado a tu cuenta" },
                            new { num = "2", bg = "var(--olive-green)", icon = "fa-inbox",     titulo = "Revisa tu correo",           desc = "Te enviaremos un código de 6 dígitos (revisa spam)" },
                            new { num = "3", bg = "var(--olive-green)", icon = "fa-key",       titulo = "Ingresa el código",          desc = "Verifica tu identidad con el código recibido" },
                            new { num = "4", bg = "var(--olive-green)", icon = "fa-lock-open", titulo = "Crea una nueva contraseña",  desc = "Establece tu nueva contraseña segura" },
                            new { num = "5", bg = "var(--olive-green)", icon = "fa-sign-in-alt",titulo = "¡Listo! Inicia sesión",    desc = "Ya podrás acceder con tu nueva contraseña" },
                        };
                    }
                    @foreach (var paso in pasos)
                    {
                        <div style="display: flex; gap: 1rem; align-items: center;">
                            <div style="width: 36px; height: 36px; background: @paso.bg; color: var(--cream); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-weight: 700; font-size: 0.85rem;">@paso.num</div>
                            <div class="admin-form-info-box" style="flex: 1; margin: 0; padding: 0.8rem 1rem;">
                                <i class="fas @paso.icon" style="font-size: 1.1rem;"></i>
                                <div><strong>@paso.titulo</strong><p>@paso.desc</p></div>
                            </div>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</section>

<!-- FAQ -->
<section class="login-features">
    <div class="container" style="max-width: 900px;">
        <div class="section-header">
            <span class="section-badge">¿Necesitas ayuda?</span>
            <h2 class="section-title">Preguntas <span class="title-accent">Frecuentes</span></h2>
        </div>
        <div style="display: grid; gap: 1.5rem;">
            <div class="feature-card" data-aos="fade-up">
                <h5 style="color: var(--dark-green); margin: 0 0 1rem; display: flex; align-items: center; gap: 0.7rem;">
                    <i class="fas fa-question-circle" style="color: var(--gold-bright);"></i>
                    ¿Qué hago si no recibo el correo?
                </h5>
                <p style="color: var(--charcoal); opacity: 0.8; margin: 0; line-height: 1.7; padding-left: 2.2rem;">
                    Primero revisa tu carpeta de spam. Si después de 10 minutos no lo encuentras, intenta solicitar un nuevo código o contacta a soporte.
                </p>
            </div>
            <div class="feature-card" data-aos="fade-up" data-aos-delay="100">
                <h5 style="color: var(--dark-green); margin: 0 0 1rem; display: flex; align-items: center; gap: 0.7rem;">
                    <i class="fas fa-question-circle" style="color: var(--gold-bright);"></i>
                    ¿El código expiró, qué hago?
                </h5>
                <p style="color: var(--charcoal); opacity: 0.8; margin: 0; line-height: 1.7; padding-left: 2.2rem;">
                    Regresa a esta página y solicita un nuevo código. Puedes hacerlo cuantas veces necesites.
                </p>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var emailInput = document.querySelector('input[type="email"]');
            if (emailInput) emailInput.focus();
        });
    </script>
}