@model AromasWeb.Abstracciones.ModeloUI.Cliente

@{
    ViewBag.Title = "Iniciar Sesión";
}

<!-- Hero Section -->
<section class="hero" style="min-height: 40vh; padding: 8rem 0 4rem;">
    <div class="hero-bg-overlay"></div>
    <div class="hero-leaves"></div>
    <div class="container hero-container" style="display: block;">
        <div class="hero-content" data-aos="fade-up" style="text-align: center;">
            <span class="hero-badge">
                <i class="fas fa-sign-in-alt"></i>
                Acceso al Sistema
            </span>
            <h1 class="hero-title" style="font-size: 3.5rem;">
                Bienvenido de
                <span class="hero-title-accent">Nuevo</span>
            </h1>
            <p class="hero-subtitle">
                Ingresa tus credenciales para continuar
            </p>
        </div>
    </div>
    <div class="scroll-indicator">
        <div class="mouse">
            <div class="wheel"></div>
        </div>
    </div>
</section>

<!-- Formulario Section -->
<section class="admin-form-section" style="background: var(--light-cream)">
    <div class="container" style="max-width: 600px;">
        <form method="post" action="/Auth/Login">
            @Html.AntiForgeryToken()

            <div class="admin-form-wrapper" data-aos="fade-up">

                @Html.ValidationSummary(true, "Por favor, corrige los siguientes errores:", new { @class = "alert alert-danger" })

                <!-- Mensaje de error -->
                @if (TempData["Error"] != null)
                {
                    <div class="admin-form-body" style="padding-bottom: 0;">
                        <div class="admin-form-info-box" style="border-color: rgba(230,33,11,0.3); background: rgba(230,33,11,0.05);">
                            <i class="fas fa-exclamation-circle" style="color: var(--red);"></i>
                            <div>
                                <strong style="color: var(--red);">Error de autenticación</strong>
                                <p>@TempData["Error"]</p>
                            </div>
                        </div>
                    </div>
                }

                <!-- Header -->
                <div class="admin-form-header">
                    <i class="fas fa-sign-in-alt"></i>
                    <h5>Iniciar Sesión</h5>
                </div>

                <div class="admin-form-body">

                    <!-- Correo Electrónico -->
                    <div class="form-group">
                        <label>
                            <i class="fas fa-envelope"></i>
                            Correo Electrónico
                        </label>
                        <input type="email" name="Correo" class="form-control" placeholder="correo@ejemplo.com" required />
                        @Html.ValidationMessageFor(model => model.Correo, "", new { @class = "text-danger" })
                    </div>

                    <!-- Contraseña -->
                    <div class="form-group">
                        <label>
                            <i class="fas fa-lock"></i>
                            Contraseña
                        </label>
                        <div style="position: relative;">
                            <input type="password" name="Contrasena" id="password-input" class="form-control" placeholder="Ingresa tu contraseña" required />
                            <button type="button" id="toggle-password" style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); background: none; border: none; color: var(--charcoal); cursor: pointer; font-size: 1.1rem; opacity: 0.5;">
                                <i class="fas fa-eye" id="eye-icon"></i>
                            </button>
                        </div>
                        @Html.ValidationMessageFor(model => model.Contrasena, "", new { @class = "text-danger" })
                    </div>

                    <!-- Recordarme y Olvidé -->
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-weight: 500; color: var(--dark-green);">
                            <input type="checkbox" name="RecordarMe" style="width: 16px; height: 16px; accent-color: var(--olive-green);">
                            Recordarme
                        </label>
                        <a href="/Auth/OlvideContrasenna" style="color: var(--gold-bright); font-weight: 600; font-size: 0.92rem;">
                            ¿Olvidaste tu contraseña?
                        </a>
                    </div>

                </div>

                <!-- Footer con botones -->
                <div class="admin-form-footer" style="flex-direction: column; gap: 0.8rem;">
                    <button type="submit" class="btn btn-primary btn-3d" style="width: 100%; justify-content: center;">
                        <span><i class="fas fa-sign-in-alt"></i> Iniciar Sesión</span>
                    </button>

                    <div style="display: flex; align-items: center; gap: 1rem;">
                        <div style="flex: 1; height: 1px; background: rgba(143, 142, 106, 0.25);"></div>
                        <span style="color: var(--charcoal); opacity: 0.5; font-size: 0.88rem;">O</span>
                        <div style="flex: 1; height: 1px; background: rgba(143, 142, 106, 0.25);"></div>
                    </div>

                    <div>
                        <p style="color: var(--charcoal); opacity: 0.7; margin-bottom: 0.6rem; text-align: center; font-size: 0.92rem;">¿No tienes una cuenta?</p>
                        <a href="/Auth/Registro" class="btn btn-secondary" style="width: 100%; justify-content: center;">
                            <span><i class="fas fa-user-plus"></i> Crear Cuenta Nueva</span>
                        </a>
                    </div>
                </div>

            </div>
        </form>
    </div>
</section>

<!-- Features Section -->
<section class="features" style="padding: 4rem 0;">
    <div class="container">
        <div class="features-grid">
            <div class="feature-card" data-aos="fade-up" data-aos-delay="0">
                <div class="feature-icon"><i class="fas fa-calendar-check"></i></div>
                <h3>Gestiona tus Reservas</h3>
                <p>Accede a tu historial y administra tus reservaciones</p>
            </div>
            <div class="feature-card" data-aos="fade-up" data-aos-delay="100">
                <div class="feature-icon"><i class="fas fa-bell"></i></div>
                <h3>Notificaciones</h3>
                <p>Recibe recordatorios de tus próximas visitas</p>
            </div>
            <div class="feature-card" data-aos="fade-up" data-aos-delay="200">
                <div class="feature-icon"><i class="fas fa-star"></i></div>
                <h3>Beneficios Exclusivos</h3>
                <p>Accede a promociones y descuentos especiales</p>
            </div>
            <div class="feature-card" data-aos="fade-up" data-aos-delay="300">
                <div class="feature-icon"><i class="fas fa-shield-alt"></i></div>
                <h3>Seguridad</h3>
                <p>Tus datos están protegidos con encriptación</p>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const togglePassword = document.getElementById('toggle-password');
            const passwordInput = document.getElementById('password-input');
            const eyeIcon = document.getElementById('eye-icon');

            if (togglePassword) {
                togglePassword.addEventListener('click', function () {
                    const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                    passwordInput.setAttribute('type', type);
                    eyeIcon.classList.toggle('fa-eye');
                    eyeIcon.classList.toggle('fa-eye-slash');
                });
            }
        });
    </script>
}