@model AromasWeb.Abstracciones.ModeloUI.Cliente

@{
    ViewBag.Title = "Iniciar Sesión";
}

<!-- ================================================
     HERO + LOGIN CARD
     ================================================ -->
<section class="login-hero">

    <div class="login-card">

        @if (TempData["Error"] != null)
        {
            <div style="padding: 1.5rem 2.5rem 0;">
                <div class="login-error-box">
                    <i class="fas fa-exclamation-circle"></i>
                    <div>
                        <strong>Error de autenticación</strong>
                        <p>@TempData["Error"]</p>
                    </div>
                </div>
            </div>
        }

        <div class="login-card-inner">

            <!-- Logo + título + subtítulo centrados -->
            <div class="login-card-heading">
                <div class="login-card-heading-logo">
                    <img src="~/images/logo.png" alt="Tsurú" />
                </div>
                <h2>Iniciar Sesión</h2>
            </div>

            <form method="post" action="/Auth/Login">
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                <!-- Email -->
                <div class="login-form-group" style="margin-bottom: 1rem;">
                    <label>
                        <i class="fas fa-envelope"></i>
                        Correo Electrónico
                    </label>
                    <input type="email" name="Correo" class="form-control"
                           placeholder="correo@ejemplo.com" required />
                    @Html.ValidationMessageFor(model => model.Correo, "", new { @class = "text-danger" })
                </div>

                <!-- Contraseña -->
                <div class="login-form-group" style="margin-bottom: 1rem;">
                    <label>
                        <i class="fas fa-lock"></i>
                        Contraseña
                    </label>
                    <div class="password-wrapper">
                        <input type="password" name="Contrasena" id="password-input"
                               class="form-control" placeholder="Ingresa tu contraseña" required />
                        <button type="button" id="toggle-password" class="toggle-password"
                                aria-label="Mostrar u ocultar contraseña">
                            <i class="fas fa-eye" id="eye-icon"></i>
                        </button>
                    </div>
                    @Html.ValidationMessageFor(model => model.Contrasena, "", new { @class = "text-danger" })
                </div>

                <!-- Recordarme + Olvidé -->
                <div class="login-options" style="margin-bottom: 1.5rem;">
                    <label class="login-remember">
                        <input type="checkbox" name="RecordarMe">
                        Recordarme
                    </label>
                    <a href="/Auth/OlvideContrasenna" class="login-forgot">
                        ¿Olvidaste tu contraseña?
                    </a>
                </div>

                <!-- Botón principal -->
                <button type="submit" class="btn btn-primary btn-block" style="margin-bottom: 1.2rem;">
                    <span><i class="fas fa-sign-in-alt"></i> Iniciar Sesión</span>
                </button>

                <!-- Divisor -->
                <div class="login-divider" style="margin-bottom: 1.2rem;">
                    <div class="login-divider-line"></div>
                    <span>O</span>
                    <div class="login-divider-line"></div>
                </div>

                <!-- Crear cuenta -->
                <p class="login-register-hint" style="margin-bottom: 0.6rem;">¿No tienes una cuenta?</p>
                <a href="/Auth/Registro" class="btn btn-secondary btn-block">
                    <span><i class="fas fa-user-plus"></i> Crear Cuenta Nueva</span>
                </a>

            </form>
        </div>
    </div>
</section>

<!-- ================================================
     FEATURE CARDS
     ================================================ -->
<section class="login-features">
    <div class="container">
        <div class="features-grid">

            <div class="feature-card" data-aos="fade-up" data-aos-delay="0">
                <div class="feature-icon"><i class="fas fa-calendar-check"></i></div>
                <h3>Gestiona tus Reservas</h3>
                <p>Accede a tu historial y administra tus reservaciones fácilmente desde un solo lugar.</p>
            </div>

            <div class="feature-card" data-aos="fade-up" data-aos-delay="100">
                <div class="feature-icon"><i class="fas fa-bell"></i></div>
                <h3>Notificaciones</h3>
                <p>Recibe recordatorios personalizados de tus próximas visitas y citas.</p>
            </div>

            <div class="feature-card" data-aos="fade-up" data-aos-delay="200">
                <div class="feature-icon"><i class="fas fa-star"></i></div>
                <h3>Beneficios Exclusivos</h3>
                <p>Accede a promociones especiales y descuentos diseñados solo para miembros.</p>
            </div>

            <div class="feature-card" data-aos="fade-up" data-aos-delay="300">
                <div class="feature-icon"><i class="fas fa-shield-alt"></i></div>
                <h3>Seguridad</h3>
                <p>Tus datos están protegidos con encriptación de nivel bancario.</p>
            </div>

        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const togglePassword = document.getElementById('toggle-password');
            const passwordInput  = document.getElementById('password-input');
            const eyeIcon        = document.getElementById('eye-icon');

            if (togglePassword) {
                togglePassword.addEventListener('click', function () {
                    const isPassword = passwordInput.getAttribute('type') === 'password';
                    passwordInput.setAttribute('type', isPassword ? 'text' : 'password');
                    eyeIcon.classList.toggle('fa-eye');
                    eyeIcon.classList.toggle('fa-eye-slash');
                });
            }
        });
    </script>
}