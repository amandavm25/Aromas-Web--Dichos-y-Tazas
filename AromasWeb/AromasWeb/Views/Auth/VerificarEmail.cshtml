@{
    ViewBag.Title = "Verificar Email";
}

<!-- Hero Section -->
<section class="hero" style="min-height: 40vh; padding: 8rem 0 4rem;">
    <div class="hero-bg-overlay"></div>
    <div class="hero-leaves"></div>
    <div class="container hero-container" style="display: block;">
        <div class="hero-content" data-aos="fade-up" style="text-align: center;">
            <span class="hero-badge">
                <i class="fas fa-envelope-open-text"></i>
                Verificación de Email
            </span>
            <h1 class="hero-title" style="font-size: 3.5rem;">
                Verifica tu
                <span class="hero-title-accent">Correo</span>
            </h1>
            <p class="hero-subtitle">
                Te enviamos un código de verificación
            </p>
        </div>
    </div>
    <div class="scroll-indicator">
        <div class="mouse">
            <div class="wheel"></div>
        </div>
    </div>
</section>

<!-- Formulario Section -->
<section class="admin-form-section" style="background: var(--light-cream)">
    <div class="container" style="max-width: 600px;">
        @using (Html.BeginForm("VerificarEmail", "Auth", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <input type="hidden" name="correo" value="@ViewBag.Correo" />

            <div class="admin-form-wrapper" data-aos="fade-up">

                <!-- Header -->
                <div class="admin-form-header">
                    <i class="fas fa-shield-alt"></i>
                    <h5>Verificación de Cuenta</h5>
                </div>

                <div class="admin-form-body">

                    <!-- Mensaje de éxito -->
                    @if (TempData["Mensaje"] != null)
                    {
                        <div class="admin-form-info-box" style="border-color: rgba(47,158,49,0.3); background: rgba(47,158,49,0.06);">
                            <i class="fas fa-check-circle" style="color: var(--green);"></i>
                            <div>
                                <strong style="color: var(--green);">¡Código enviado!</strong>
                                <p>@TempData["Mensaje"]</p>
                            </div>
                        </div>
                    }

                    <!-- Mensaje de error -->
                    @if (TempData["Error"] != null)
                    {
                        <div class="admin-form-info-box" style="border-color: rgba(231,76,60,0.3); background: rgba(231,76,60,0.06);">
                            <i class="fas fa-exclamation-triangle" style="color: var(--red);"></i>
                            <div>
                                <strong style="color: var(--red);">Error</strong>
                                <p>@TempData["Error"]</p>
                            </div>
                        </div>
                    }

                    <!-- Información -->
                    <div class="admin-form-info-box">
                        <i class="fas fa-info-circle"></i>
                        <div>
                            <strong>¡Bienvenido a Aromas!</strong>
                            <p>Para completar tu registro, hemos enviado un código de 6 dígitos a <strong>@ViewBag.Correo</strong>. El código expira en 15 minutos.</p>
                        </div>
                    </div>

                    <!-- Código -->
                    <div class="form-group">
                        <label>
                            <i class="fas fa-key"></i>
                            Código de Verificación
                        </label>
                        <input type="text"
                               name="codigo"
                               class="form-control"
                               placeholder="123456"
                               maxlength="6"
                               pattern="[0-9]{6}"
                               style="font-size: 24px; letter-spacing: 8px; text-align: center; font-weight: bold;"
                               required
                               autofocus />
                        <small class="admin-form-hint">
                            <i class="fas fa-info-circle"></i>
                            Ingresa el código de 6 dígitos que recibiste por correo
                        </small>
                    </div>

                    <!-- No recibí el código -->
                    <div style="text-align: center; margin-top: 1.5rem;">
                        <p style="color: var(--charcoal); opacity: 0.7; margin-bottom: 0.5rem;">¿No recibiste el código?</p>
                        <a href="@Url.Action("ReenviarCodigoVerificacion", "Auth", new { correo = ViewBag.Correo })" style="color: var(--gold-bright); font-weight: 600; text-decoration: underline;">
                            Reenviar código
                        </a>
                    </div>

                </div>

                <!-- Footer -->
                <div class="admin-form-footer">
                    <button type="button" class="btn btn-secondary" onclick="window.location.href='@Url.Action("Login", "Auth")'">
                        <i class="fas fa-arrow-left"></i>
                        <span>Volver al Login</span>
                    </button>
                    <button type="submit" class="btn btn-primary btn-3d">
                        <i class="fas fa-check"></i>
                        <span>Verificar Email</span>
                    </button>
                </div>

            </div>
        }
    </div>
</section>

<!-- Pasos Section -->
<section class="features" style="padding: 4rem 0;">
    <div class="container" style="max-width: 900px;">
        <div class="section-header">
            <span class="section-badge">Solo un paso más</span>
            <h2 class="section-title">
                ¿Por qué verificar tu <span class="title-accent">Email?</span>
            </h2>
        </div>
        <div style="display: grid; gap: 1.5rem;">
            <div class="feature-card" style="padding: 2rem; margin: 0;" data-aos="fade-up">
                <h5 style="color: var(--dark-green); margin: 0 0 1rem; display: flex; align-items: center; gap: 0.7rem;">
                    <i class="fas fa-shield-alt" style="color: var(--gold-bright);"></i>
                    Seguridad de tu cuenta
                </h5>
                <p style="color: var(--charcoal); opacity: 0.8; margin: 0; line-height: 1.7; padding-left: 2.2rem;">
                    Confirmamos que eres el dueño del correo para proteger tu cuenta y evitar registros fraudulentos.
                </p>
            </div>
            <div class="feature-card" style="padding: 2rem; margin: 0;" data-aos="fade-up" data-aos-delay="100">
                <h5 style="color: var(--dark-green); margin: 0 0 1rem; display: flex; align-items: center; gap: 0.7rem;">
                    <i class="fas fa-bell" style="color: var(--gold-bright);"></i>
                    Notificaciones importantes
                </h5>
                <p style="color: var(--charcoal); opacity: 0.8; margin: 0; line-height: 1.7; padding-left: 2.2rem;">
                    Recibirás confirmaciones de reservas, recordatorios y ofertas exclusivas directamente en tu correo.
                </p>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Auto-focus en el input del código
            var codigoInput = document.querySelector('input[name="codigo"]');
            if (codigoInput) {
                codigoInput.focus();

                // Solo permitir números
                codigoInput.addEventListener('input', function(e) {
                    this.value = this.value.replace(/[^0-9]/g, '');
                });
            }
        });
    </script>
}