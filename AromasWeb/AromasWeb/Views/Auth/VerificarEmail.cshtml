@{
    ViewBag.Title = "Verificar Email";
}

<section class="login-hero registro-hero">
    <div class="login-card registro-card">

        @if (TempData["Mensaje"] != null)
        {
            <div style="padding: 1.5rem 2.5rem 0;">
                <div class="login-error-box" style="background: rgba(47,158,49,0.05); border-color: rgba(47,158,49,0.3);">
                    <i class="fas fa-check-circle" style="color: var(--green);"></i>
                    <div>
                        <strong style="color: var(--green);">¡Código enviado!</strong>
                        <p>@TempData["Mensaje"]</p>
                    </div>
                </div>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div style="padding: 1.5rem 2.5rem 0;">
                <div class="login-error-box">
                    <i class="fas fa-exclamation-circle"></i>
                    <div>
                        <strong>Error</strong>
                        <p>@TempData["Error"]</p>
                    </div>
                </div>
            </div>
        }

        <div class="login-card-inner">

            <div class="login-card-heading">
               <h2>Verifica tu Correo</h2>
                <p>Te enviamos un código de verificación</p>
            </div>

            @using (Html.BeginForm("VerificarEmail", "Auth", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="correo" value="@ViewBag.Correo" />

                <!-- Información -->
                <div class="admin-form-info-box" style="margin-bottom: 1.2rem;">
                    <i class="fas fa-info-circle"></i>
                    <div>
                        <strong>¡Bienvenido a Tsurú!</strong>
                        <p>Para completar tu registro, hemos enviado un código de 6 dígitos a <strong>@ViewBag.Correo</strong>. El código expira en 15 minutos.</p>
                    </div>
                </div>

                <!-- Código -->
                <div class="form-group" style="margin-bottom: 1rem;">
                    <label><i class="fas fa-key"></i> Código de Verificación</label>
                    <input type="text"
                           name="codigo"
                           class="form-control"
                           placeholder="123456"
                           maxlength="6"
                           pattern="[0-9]{6}"
                           style="font-size: 24px; letter-spacing: 8px; text-align: center; font-weight: bold;"
                           required
                           autofocus />
                    <small class="admin-form-hint">
                        <i class="fas fa-info-circle"></i>
                        Ingresa el código de 6 dígitos que recibiste por correo
                    </small>
                </div>

                <!-- Reenviar -->
                <div style="text-align: center; margin-bottom: 1.5rem;">
                    <p style="color: var(--charcoal); opacity: 0.7; margin-bottom: 0.4rem; font-size: 0.88rem;">¿No recibiste el código?</p>
                    <a href="@Url.Action("ReenviarCodigoVerificacion", "Auth", new { correo = ViewBag.Correo })" style="color: var(--gold-bright); font-weight: 600; text-decoration: underline; font-size: 0.88rem;">
                        Reenviar código
                    </a>
                </div>

                <!-- Botones -->
                <div class="admin-form-footer" style="padding: 1.2rem 0 0; background: transparent; border-top: 1px solid rgba(143,142,106,0.12);">
                    <button type="button" class="btn btn-secondary" onclick="window.location.href='@Url.Action("Login", "Auth")'">
                        <i class="fas fa-arrow-left"></i>
                        <span>Volver al Login</span>
                    </button>
                    <button type="submit" class="btn btn-primary btn-3d">
                        <i class="fas fa-check"></i>
                        <span>Verificar Email</span>
                    </button>
                </div>
            }
        </div>
    </div>
</section>

<!-- Por qué verificar -->
<section class="login-features">
    <div class="container" style="max-width: 900px;">
        <div class="section-header">
            <span class="section-badge">Solo un paso más</span>
            <h2 class="section-title">¿Por qué verificar tu <span class="title-accent">Email?</span></h2>
        </div>
        <div class="features-grid">
            <div class="feature-card" data-aos="fade-up">
                <div class="feature-icon"><i class="fas fa-shield-alt"></i></div>
                <h3>Seguridad de tu cuenta</h3>
                <p>Confirmamos que eres el dueño del correo para proteger tu cuenta y evitar registros fraudulentos.</p>
            </div>
            <div class="feature-card" data-aos="fade-up" data-aos-delay="100">
                <div class="feature-icon"><i class="fas fa-bell"></i></div>
                <h3>Notificaciones importantes</h3>
                <p>Recibirás confirmaciones de reservas, recordatorios y ofertas exclusivas directamente en tu correo.</p>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var codigoInput = document.querySelector('input[name="codigo"]');
            if (codigoInput) {
                codigoInput.focus();
                codigoInput.addEventListener('input', function(e) {
                    this.value = this.value.replace(/[^0-9]/g, '');
                });
            }
        });
    </script>
}