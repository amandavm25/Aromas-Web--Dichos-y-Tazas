    <main>
        @if (TempData["Mensaje"] != null)
        {
            <div style="position: fixed; top: 100px; right: 20px; z-index: 10000; animation: slideInRight 0.5s ease;">
                <div style="background: linear-gradient(135deg, var(--green), #229954); color: white; padding: 1.5rem 2rem; border-radius: 15px; box-shadow: 0 8px 32px rgba(0,0,0,0.2); display: flex; align-items: center; gap: 1rem; min-width: 300px;">
                    <i class="fas fa-check-circle" style="font-size: 1.5rem;"></i>
                    <span style="font-weight: 600;">@TempData["Mensaje"]</span>
                </div>
            </div>
            <script>setTimeout(function(){var m=document.querySelector('[style*="slideInRight"]');if(m){m.style.animation='slideOutRight 0.5s ease';setTimeout(function(){m.remove();},500);}},4000);</script>
        }
        @if (TempData["Error"] != null)
        {
            <div style="position: fixed; top: 100px; right: 20px; z-index: 10000; animation: slideInRight 0.5s ease;">
                <div style="background: linear-gradient(135deg, var(--red), #c0392b); color: white; padding: 1.5rem 2rem; border-radius: 15px; box-shadow: 0 8px 32px rgba(0,0,0,0.2); display: flex; align-items: center; gap: 1rem; min-width: 300px;">
                    <i class="fas fa-exclamation-triangle" style="font-size: 1.5rem;"></i>
                    <span style="font-weight: 600;">@TempData["Error"]</span>
                </div>
            </div>
            <script>setTimeout(function(){var e=document.querySelector('[style*="slideInRight"]');if(e){e.style.animation='slideOutRight 0.5s ease';setTimeout(function(){e.remove();},500);}},4000);</script>
        }

        @RenderBody()
    </main>

