@using System.Text.Json
@{
    var usuarioTipo = Context.Session.GetString("UsuarioTipo");
    var usuarioNombre = Context.Session.GetString("UsuarioNombre");
    var usuarioCorreo = Context.Session.GetString("UsuarioCorreo");
    var estaAutenticado = !string.IsNullOrEmpty(usuarioTipo);
    var esAdmin = usuarioTipo == "admin";
    var esCliente = usuarioTipo == "cliente";
    var esEmpleado = usuarioTipo == "empleado";

    // Cargar IDs de permisos del rol desde sesión
    HashSet<int> permisosRol = new HashSet<int>();
    if (esEmpleado)
    {
        try
        {
            var json = Context.Session.GetString("PermisosRol");
            if (!string.IsNullOrEmpty(json))
            {
                var lista = JsonSerializer.Deserialize<List<int>>(json);
                if (lista != null) permisosRol = new HashSet<int>(lista);
            }
        }
        catch { }
    }

    // Cargar mapa nombre → id de TODOS los permisos
    // Se guarda en sesión al hacer login
    Dictionary<string, int> mapaPermisos = new Dictionary<string, int>();
    if (esEmpleado)
    {
        try
        {
            var jsonMapa = Context.Session.GetString("MapaPermisos");
            if (!string.IsNullOrEmpty(jsonMapa))
            {
                var mapa = JsonSerializer.Deserialize<Dictionary<string, int>>(jsonMapa);
                if (mapa != null) mapaPermisos = mapa;
            }
        }
        catch { }
    }

    // Resuelve el id de un permiso por su nombre (devuelve -1 si no existe en BD)
    int IdPermiso(string nombre) =>
        mapaPermisos.TryGetValue(nombre, out int id) ? id : -1;

    // true si admin o si el empleado tiene ese permiso asignado
    bool TienePermiso(string nombre) =>
        esAdmin || permisosRol.Contains(IdPermiso(nombre));

    // Visibilidad de dropdowns
    bool hayInsumos = TienePermiso("Ver Insumos")
                   || TienePermiso("Ver Categorias Insumos")
                   || TienePermiso("Ver Movimientos Insumos");

    bool hayRecetas = TienePermiso("Ver Recetas")
                   || TienePermiso("Ver Categorias Recetas");

    bool hayPromociones = TienePermiso("Ver Promociones")
                       || TienePermiso("Ver Tipos Promocion");

    bool hayRRHH = TienePermiso("Ver Empleados")
                || TienePermiso("Ver Tarifas")
                || TienePermiso("Ver Asistencias")
                || TienePermiso("Ver Planillas")
                || TienePermiso("Ver Solicitudes Vacaciones")
                || TienePermiso("Aprobar Vacaciones");

    bool hayAsistenciaPropia = TienePermiso("Registrar Asistencia");
}

