@model AromasWeb.Abstracciones.ModeloUI.Reserva

@{
    ViewBag.Title = "Reservar Mesa";
}

<!-- Hero Section -->
<section class="hero" style="min-height: 40vh; padding: 8rem 0 4rem;">
    <div class="hero-bg-overlay"></div>
    <div class="hero-leaves"></div>
    <div class="container hero-container" style="display: block;">
        <div class="hero-content" data-aos="fade-up" style="text-align: center;">
            <span class="hero-badge">
                <i class="fas fa-calendar-plus"></i>
                Nueva Reserva
            </span>
            <h1 class="hero-title" style="font-size: 3.5rem;">
                Reservar una
                <span class="hero-title-accent">Mesa</span>
            </h1>
            <p class="hero-subtitle">
                Complete el formulario para hacer su reserva y disfrutar de una experiencia única
            </p>
        </div>
    </div>
    <div class="scroll-indicator">
        <div class="mouse"><div class="wheel"></div></div>
    </div>
</section>

<!-- Formulario Section -->
<section class="admin-form-section">
    <div class="container" style="max-width: 80%;">

        <!-- Tarjeta del cliente (patrón MiPerfil: modal-entity-header) -->
        <div class="admin-modal" data-aos="fade-up" style="margin-bottom: 2rem;">
            <div class="modal-entity-header">

                <!-- Avatar -->
                <div class="modal-entity-avatar">
                    <i class="fas fa-user"></i>
                </div>

                <!-- Nombre y datos -->
                <div style="flex: 1;">
                    <h4 class="modal-entity-name">@ViewBag.NombreCliente</h4>
                    <p class="modal-entity-sub">
                        <i class="fas fa-envelope" style="color: var(--olive-green); margin-right: 0.4rem;"></i>@ViewBag.Correo
                    </p>
                    <div class="modal-entity-meta">
                        <div class="modal-entity-meta-item">
                            <small><i class="fas fa-id-card"></i> Identificación</small>
                            <p>@ViewBag.Identificacion</p>
                        </div>
                        <div class="modal-entity-meta-item">
                            <small><i class="fas fa-phone"></i> Teléfono</small>
                            <p>@ViewBag.Telefono</p>
                        </div>
                    </div>
                </div>

            </div>
        </div>

        @using (Html.BeginForm("CrearReserva", "Reserva", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <input type="hidden" name="IdCliente"       value="@ViewBag.IdCliente" />
            <input type="hidden" name="NombreCliente"   value="@ViewBag.NombreCliente" />
            <input type="hidden" name="TelefonoCliente" value="@ViewBag.Telefono" />

            <div class="admin-form-wrapper" data-aos="fade-up">
                @Html.ValidationSummary(true, "Por favor, corrige los siguientes errores:", new { @class = "alert alert-danger" })

                <!-- Sección Detalles de la Reserva -->
                <div class="admin-form-header">
                    <i class="fas fa-calendar-alt"></i>
                    <h5>Detalles de la Reserva</h5>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label><i class="fas fa-calendar"></i> Fecha</label>
                        @Html.EditorFor(model => model.Fecha, new { htmlAttributes = new { @class = "form-control", type = "date", min = DateTime.Now.ToString("yyyy-MM-dd"), required = "required" } })
                        @Html.ValidationMessageFor(model => model.Fecha, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group">
                        <label><i class="fas fa-clock"></i> Hora</label>
                        <select name="Hora" class="form-control" required>
                            <option value="">-- Selecciona una hora --</option>
                            <option value="11:00">11:00 AM</option>
                            <option value="11:30">11:30 AM</option>
                            <option value="12:00">12:00 PM</option>
                            <option value="12:30">12:30 PM</option>
                            <option value="13:00">1:00 PM</option>
                            <option value="13:30">1:30 PM</option>
                            <option value="14:00">2:00 PM</option>
                            <option value="14:30">2:30 PM</option>
                            <option value="18:00">6:00 PM</option>
                            <option value="18:30">6:30 PM</option>
                            <option value="19:00">7:00 PM</option>
                            <option value="19:30">7:30 PM</option>
                            <option value="20:00">8:00 PM</option>
                            <option value="20:30">8:30 PM</option>
                            <option value="21:00">9:00 PM</option>
                        </select>
                        @Html.ValidationMessageFor(model => model.Hora, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="form-group">
                    <label><i class="fas fa-users"></i> Número de Personas</label>
                    <select name="CantidadPersonas" class="form-control" required>
                        @for (int i = 1; i <= 10; i++)
                        {
                            <option value="@i" @@(i == 2 ? "selected" : "")>@i persona@(i > 1 ? "s" : "")</option>
                        }
                        <option value="">10+ personas (contactar)</option>
                    </select>
                    @Html.ValidationMessageFor(model => model.CantidadPersonas, "", new { @class = "text-danger" })
                </div>

                <div class="form-group">
                    <label><i class="fas fa-comment"></i> Mensaje o Solicitudes Especiales</label>
                    <textarea name="Observaciones" class="form-control" rows="4"
                              placeholder="Cuéntanos sobre tu reserva (alergias, preferencias de mesa, celebraciones, etc.)"
                              style="resize: vertical;"></textarea>
                    <small style="display: block; margin-top: 0.5rem; color: var(--charcoal); opacity: 0.7;">
                        <i class="fas fa-info-circle" style="color: var(--olive-green);"></i>
                        Opcional - Máximo 500 caracteres
                    </small>
                </div>

                <!-- Información Importante -->
                <div style="background: rgba(143,142,106,0.08); padding: 1.5rem; border-radius: 15px; margin: 0 0 1.5rem; border-left: 5px solid var(--olive-green);">
                    <h6 style="color: var(--dark-green); margin: 0 0 1rem; font-weight: 700; display: flex; align-items: center; gap: 0.5rem;">
                        <i class="fas fa-info-circle" style="color: var(--gold);"></i> Información Importante
                    </h6>
                    <ul style="margin: 0; padding-left: 1.5rem; color: var(--charcoal); opacity: 0.85; line-height: 2;">
                        <li><i class="fas fa-check" style="color: var(--green); margin-right: 0.5rem;"></i>Recibirá una confirmación por teléfono en las próximas horas</li>
                        <li><i class="fas fa-check" style="color: var(--green); margin-right: 0.5rem;"></i>Por favor llegue 10 minutos antes de su hora reservada</li>
                        <li><i class="fas fa-check" style="color: var(--green); margin-right: 0.5rem;"></i>Para grupos mayores a 10 personas, contacte directamente al restaurante</li>
                        <li><i class="fas fa-check" style="color: var(--green); margin-right: 0.5rem;"></i>Las reservas se mantienen por 15 minutos después de la hora programada</li>
                    </ul>
                </div>

                <!-- Botones -->
                <div class="admin-form-footer">
                    <button type="button" class="btn btn-secondary" onclick="window.location.href='@Url.Action("MisReservas", "Reserva")'">
                        <span><i class="fas fa-times"></i> Cancelar</span>
                    </button>
                    <button type="submit" class="btn btn-primary btn-3d">
                        <span><i class="fas fa-check"></i> Enviar Reserva</span>
                    </button>
                </div>
            </div>
        }
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/reserva.js"></script>
}