@model AromasWeb.Abstracciones.ModeloUI.Reserva

@{
    ViewBag.Title = "Editar Mi Reserva";
}

<!-- Hero Section -->
<section class="hero" style="min-height: 40vh; padding: 8rem 0 4rem;">
    <div class="hero-bg-overlay"></div>
    <div class="hero-leaves"></div>
    <div class="container hero-container" style="display: block;">
        <div class="hero-content" data-aos="fade-up" style="text-align: center;">
            <span class="hero-badge">
                <i class="fas fa-edit"></i>
                Modificar Reserva
            </span>
            <h1 class="hero-title" style="font-size: 3.5rem;">
                Editar Mi
                <span class="hero-title-accent">Reserva</span>
            </h1>
            <p class="hero-subtitle">
                Actualiza los detalles de tu reserva fácilmente
            </p>
        </div>
    </div>
    <div class="scroll-indicator">
        <div class="mouse"><div class="wheel"></div></div>
    </div>
</section>

<!-- Formulario Section -->
<section class="admin-form-section">
    <div class="container" style="max-width: 80%;">
        @using (Html.BeginForm("EditarMiReserva", "Reserva", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(model => model.IdReserva)
            @Html.HiddenFor(model => model.IdCliente)

            <div class="admin-form-wrapper" data-aos="fade-up">
                @Html.ValidationSummary(true, "Por favor, corrige los siguientes errores:", new { @class = "alert alert-danger" })

                <!-- Reserva actual (solo lectura) -->
                <div class="admin-form-header">
                    <i class="fas fa-info-circle"></i>
                    <h5>Reserva Actual</h5>
                </div>

                <div style="margin: 0 0 1.5rem; padding: 1.5rem; background: var(--cream); border-radius: 20px; border-left: 5px solid var(--olive-green);">
                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1.5rem;">
                        <div>
                            <small style="color: var(--charcoal); opacity: 0.7; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; display: block; margin-bottom: 0.3rem;">
                                <i class="fas fa-hashtag" style="color: var(--olive-green);"></i> Reserva #
                            </small>
                            <strong style="color: var(--dark-green); font-size: 1.3rem;">@Model.IdReserva</strong>
                        </div>
                        <div>
                            <small style="color: var(--charcoal); opacity: 0.7; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; display: block; margin-bottom: 0.3rem;">
                                <i class="fas fa-check-circle" style="color: var(--olive-green);"></i> Estado
                            </small>
                            <span style="background: var(--yellow); color: var(--white); padding: 0.4rem 1rem; border-radius: 15px; font-size: 0.9rem; font-weight: 600; display: inline-block;">
                                @Model.Estado
                            </span>
                        </div>
                        <div>
                            <small style="color: var(--charcoal); opacity: 0.7; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; display: block; margin-bottom: 0.3rem;">
                                <i class="fas fa-calendar-plus" style="color: var(--olive-green);"></i> Creada
                            </small>
                            <strong style="color: var(--dark-green);">@Model.FechaCreacionFormateada</strong>
                        </div>
                    </div>
                </div>

                <!-- Nuevos detalles -->
                <div class="admin-form-header">
                    <i class="fas fa-calendar-alt"></i>
                    <h5>Nuevos Detalles</h5>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label><i class="fas fa-calendar"></i> Fecha de la Reserva</label>
                        @Html.EditorFor(model => model.Fecha, new { htmlAttributes = new { @class = "form-control", type = "date", min = DateTime.Now.ToString("yyyy-MM-dd") } })
                        @Html.ValidationMessageFor(model => model.Fecha, "", new { @class = "text-danger" })
                        <small style="display: block; margin-top: 0.5rem; color: var(--charcoal); opacity: 0.7;">
                            <i class="fas fa-info-circle" style="color: var(--gold-bright);"></i>
                            Puedes cambiar la fecha con al menos 24 horas de anticipación
                        </small>
                    </div>
                    <div class="form-group">
                        <label><i class="fas fa-clock"></i> Hora de la Reserva</label>
                        <select name="Hora" class="form-control" required>
                            <option value="">-- Selecciona una hora --</option>
                            <option value="11:00">11:00 AM</option>
                            <option value="11:30">11:30 AM</option>
                            <option value="12:00">12:00 PM</option>
                            <option value="12:30">12:30 PM</option>
                            <option value="13:00">1:00 PM</option>
                            <option value="13:30">1:30 PM</option>
                            <option value="14:00">2:00 PM</option>
                            <option value="14:30">2:30 PM</option>
                            <option value="18:00">6:00 PM</option>
                            <option value="18:30">6:30 PM</option>
                            <option value="19:00">7:00 PM</option>
                            <option value="19:30">7:30 PM</option>
                            <option value="20:00">8:00 PM</option>
                            <option value="20:30">8:30 PM</option>
                            <option value="21:00">9:00 PM</option>
                        </select>
                        @Html.ValidationMessageFor(model => model.Hora, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="form-group">
                    <label><i class="fas fa-users"></i> Cantidad de Personas</label>
                    @Html.EditorFor(model => model.CantidadPersonas, new { htmlAttributes = new { @class = "form-control", type = "number", min = "1", max = "20", placeholder = "1" } })
                    @Html.ValidationMessageFor(model => model.CantidadPersonas, "", new { @class = "text-danger" })
                    <small style="display: block; margin-top: 0.5rem; color: var(--charcoal); opacity: 0.7;">
                        <i class="fas fa-info-circle" style="color: var(--gold-bright);"></i>
                        Máximo 20 personas por reserva
                    </small>
                </div>

                <div class="form-group">
                    <label><i class="fas fa-comment"></i> Observaciones o Solicitudes Especiales</label>
                    <textarea name="Observaciones" class="form-control" rows="4" placeholder="Añade cualquier solicitud especial (alergias, preferencias de mesa, celebraciones, etc.)" style="resize: vertical;">@Model.Observaciones</textarea>
                    <small style="display: block; margin-top: 0.5rem; color: var(--charcoal); opacity: 0.7;">
                        <i class="fas fa-info-circle" style="color: var(--olive-green);"></i>
                        Opcional - Máximo 500 caracteres
                    </small>
                </div>

                <!-- Políticas -->
                <div style="background: rgba(197,179,88,0.08); padding: 1.5rem; border-radius: 15px; margin: 0 0 1.5rem; border-left: 5px solid var(--gold);">
                    <h6 style="color: var(--dark-green); margin: 0 0 1rem; font-weight: 700; display: flex; align-items: center; gap: 0.5rem;">
                        <i class="fas fa-exclamation-circle" style="color: var(--gold);"></i> Políticas de Modificación
                    </h6>
                    <ul style="margin: 0; padding-left: 1.5rem; color: var(--charcoal); opacity: 0.85; line-height: 2;">
                        <li><i class="fas fa-clock" style="color: var(--gold); margin-right: 0.5rem;"></i>Los cambios deben realizarse con al menos 24 horas de anticipación</li>
                        <li><i class="fas fa-redo" style="color: var(--gold); margin-right: 0.5rem;"></i>Solo puedes modificar una reserva hasta 3 veces</li>
                        <li><i class="fas fa-ban" style="color: var(--gold); margin-right: 0.5rem;"></i>Si necesitas cancelar, hazlo desde "Mis Reservas"</li>
                        <li><i class="fas fa-phone" style="color: var(--gold); margin-right: 0.5rem;"></i>Para cambios de última hora, contacta al restaurante directamente</li>
                    </ul>
                </div>

                <!-- Botones -->
                <div class="admin-form-footer">
                    <button type="button" class="btn btn-secondary" onclick="window.location.href='@Url.Action("MisReservas", "Reserva")'">
                        <span><i class="fas fa-times"></i> Cancelar</span>
                    </button>
                    <button type="submit" class="btn btn-primary btn-3d">
                        <span><i class="fas fa-check"></i> Guardar Cambios</span>
                    </button>
                </div>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script src="~/js/reserva.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const horaActual = '@Model.HoraFormateada';
            const selectHora = document.querySelector('select[name="Hora"]');
            if (selectHora && horaActual) {
                for (let i = 0; i < selectHora.options.length; i++) {
                    if (selectHora.options[i].value === horaActual) {
                        selectHora.options[i].selected = true;
                        break;
                    }
                }
            }
        });
    </script>
}