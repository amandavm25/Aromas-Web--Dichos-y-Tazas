<div class="modal fade admin-modal modal-olive" id="modalDetallesReserva" tabindex="-1" aria-labelledby="modalDetallesReservaLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <!-- Header -->
            <div class="modal-header">
                <h5 class="modal-title" id="modalDetallesReservaLabel">
                    <div class="modal-icon">
                        <i class="fas fa-calendar-check"></i>
                    </div>
                    Detalles de la Reserva
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <!-- Body -->
            <div class="modal-body">

                <!-- Información del Cliente -->
                <div class="modal-entity-header entity-block">
                    <h5 id="detalles-cliente-reserva" class="modal-entity-name"></h5>
                    <div class="modal-entity-meta">
                        <div class="modal-entity-meta-item">
                            <small><i class="fas fa-phone"></i> Teléfono:</small>
                            <p id="detalles-telefono-text-reserva" class="modal-data-value"></p>
                        </div>
                    </div>
                </div>

                <!-- ID, Estado -->
                <div class="modal-data-grid-2">
                    <div class="modal-data-cell">
                        <label class="modal-data-label">
                            <i class="fas fa-hashtag"></i> ID de Reserva
                        </label>
                        <p id="detalles-id-reserva" class="modal-data-value"></p>
                    </div>
                    <div class="modal-data-cell">
                        <label class="modal-data-label">
                            <i class="fas fa-toggle-on"></i> Estado
                        </label>
                        <span id="detalles-estado-badge-reserva"
                              class="badge"
                              style="font-size:1rem;padding:0.6rem 1.5rem;border-radius:50px;display:inline-flex;align-items:center;gap:0.5rem;font-weight:600;"></span>
                    </div>
                </div>

                <!-- Fecha y Hora -->
                <h6 class="modal-subsection-title">
                    <i class="fas fa-calendar-alt"></i> Fecha y Hora
                </h6>
                <div class="modal-data-grid-2">
                    <div class="modal-data-cell">
                        <label class="modal-data-label">
                            <i class="fas fa-calendar"></i> Fecha
                        </label>
                        <p id="detalles-fecha-reserva" class="modal-data-value"></p>
                    </div>
                    <div class="modal-data-cell">
                        <label class="modal-data-label">
                            <i class="fas fa-clock"></i> Hora
                        </label>
                        <p id="detalles-hora-reserva" class="modal-data-value"></p>
                    </div>
                </div>

                <!-- Resumen -->
                <h6 class="modal-subsection-title">
                    <i class="fas fa-users"></i> Detalle de Asistentes
                </h6>
                <div class="modal-summary">
                    <div class="modal-summary-grid">
                        <div>
                            <label class="modal-summary-label">
                                <i class="fas fa-user-friends"></i> Cantidad de Personas
                            </label>
                            <p id="detalles-personas-reserva" class="modal-summary-value summary-extra"></p>
                        </div>
                    </div>
                </div>

                <!-- Observaciones -->
                <div id="detalles-observaciones-container" style="display: none; margin-top: 1.5rem;">
                    <h6 class="modal-subsection-title">
                        <i class="fas fa-comment"></i> Observaciones
                    </h6>
                    <div class="modal-section">
                        <p id="detalles-observaciones-reserva" class="modal-data-value" style="font-style: italic;"></p>
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <span><i class="fas fa-times"></i> Cerrar</span>
                </button>
            </div>
        </div>
    </div>
</div>