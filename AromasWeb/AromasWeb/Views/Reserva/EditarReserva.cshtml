@model AromasWeb.Abstracciones.ModeloUI.Reserva

@{
    ViewBag.Title = "Editar Reserva";
}

<!-- Hero Section -->
<section class="hero" style="min-height: 40vh; padding: 8rem 0 4rem;">
    <div class="hero-bg-overlay"></div>
    <div class="hero-leaves"></div>
    <div class="container hero-container" style="display: block;">
        <div class="hero-content" data-aos="fade-up" style="text-align: center;">
            <span class="hero-badge">
                <i class="fas fa-edit"></i>
                Actualizar Información
            </span>
            <h1 class="hero-title" style="font-size: 3.5rem;">
                Editar
                <span class="hero-title-accent">Reserva</span>
            </h1>
            <p class="hero-subtitle">
                Modifica los detalles de la reserva del cliente
            </p>
        </div>
    </div>
    <div class="scroll-indicator">
        <div class="mouse"><div class="wheel"></div></div>
    </div>
</section>

<!-- Formulario Section -->
<section class="admin-form-section">
    <div class="container" style="max-width: 80%;">
        @using (Html.BeginForm("EditarReserva", "Reserva", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(model => model.IdReserva)
            @Html.HiddenFor(model => model.IdCliente)
            @Html.HiddenFor(model => model.NombreCliente)
            @Html.HiddenFor(model => model.TelefonoCliente)

            <div class="admin-form-wrapper" data-aos="fade-up">
                @Html.ValidationSummary(true, "Por favor, corrige los siguientes errores:", new { @class = "alert alert-danger" })

                <!-- Datos del Cliente (solo lectura) -->
                <div class="admin-form-header">
                    <i class="fas fa-user-tie"></i>
                    <h5>Datos del Cliente</h5>
                </div>

                <div style="margin: 0 0 1.5rem; padding: 1.5rem; background: var(--cream); border-radius: 20px; border-left: 5px solid var(--olive-green);">
                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1.5rem;">
                        <div>
                            <small style="color: var(--charcoal); opacity: 0.7; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; display: block; margin-bottom: 0.3rem;">
                                <i class="fas fa-user" style="color: var(--olive-green);"></i> Nombre
                            </small>
                            <strong style="color: var(--dark-green);">@Model.NombreCliente</strong>
                        </div>
                        <div>
                            <small style="color: var(--charcoal); opacity: 0.7; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; display: block; margin-bottom: 0.3rem;">
                                <i class="fas fa-phone" style="color: var(--olive-green);"></i> Teléfono
                            </small>
                            <strong style="color: var(--dark-green);">@Model.TelefonoCliente</strong>
                        </div>
                        <div>
                            <small style="color: var(--charcoal); opacity: 0.7; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; display: block; margin-bottom: 0.3rem;">
                                <i class="fas fa-calendar-plus" style="color: var(--olive-green);"></i> Fecha de Creación
                            </small>
                            <strong style="color: var(--dark-green);">@Model.FechaCreacionFormateada</strong>
                        </div>
                    </div>
                </div>

                <!-- Detalles de la Reserva -->
                <div class="admin-form-header">
                    <i class="fas fa-calendar-alt"></i>
                    <h5>Detalles de la Reserva</h5>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label><i class="fas fa-calendar"></i> Fecha</label>
                        @Html.EditorFor(model => model.Fecha, new { htmlAttributes = new { @class = "form-control", type = "date", id = "inputFecha", name="Fecha", min = DateTime.Now.ToString("yyyy-MM-dd"), required = "required" } })
                        @Html.ValidationMessageFor(model => model.Fecha, "", new { @class = "text-danger" })
                        <small id="aviso-cerrado" style="display:none; color: var(--red); margin-top: 0.4rem;">
                            <i class="fas fa-times-circle"></i> El restaurante no abre ese día (lunes y martes).
                        </small>
                    </div>
                    <div class="form-group">
                        <label><i class="fas fa-clock"></i> Hora</label>
                        <select name="Hora" id="selectHora" class="form-control" required>
                            <option value="">-- Primero selecciona una fecha --</option>
                        </select>
                        @Html.ValidationMessageFor(model => model.Hora, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="form-group">
                    <label><i class="fas fa-users"></i> Cantidad de Personas</label>
                    @Html.EditorFor(model => model.CantidadPersonas, new { htmlAttributes = new { @class = "form-control", type = "number", min = "1", max = "20", placeholder = "1" } })
                    @Html.ValidationMessageFor(model => model.CantidadPersonas, "", new { @class = "text-danger" })
                </div>

                <div class="form-group">
                    <label><i class="fas fa-check-circle"></i> Estado de la Reserva</label>
                    <select name="Estado" class="form-control" required>
                        <option value="Pendiente"  @@(Model.Estado == "Pendiente"  ? "selected" : "")>Pendiente</option>
                        <option value="Confirmada" @@(Model.Estado == "Confirmada" ? "selected" : "")>Confirmada</option>
                        <option value="Completada" @@(Model.Estado == "Completada" ? "selected" : "")>Completada</option>
                        <option value="Cancelada"  @@(Model.Estado == "Cancelada"  ? "selected" : "")>Cancelada</option>
                    </select>
                    @Html.ValidationMessageFor(model => model.Estado, "", new { @class = "text-danger" })
                </div>

                <div class="form-group">
                    <label><i class="fas fa-comment"></i> Observaciones del Cliente</label>
                    <textarea name="Observaciones" class="form-control" rows="4" placeholder="Notas especiales, alergias, preferencias, etc." style="resize: vertical;">@Model.Observaciones</textarea>
                    <small style="display: block; margin-top: 0.5rem; color: var(--charcoal); opacity: 0.7;">
                        <i class="fas fa-info-circle" style="color: var(--olive-green);"></i>
                        Máximo 500 caracteres
                    </small>
                </div>

                <!-- Botones -->
                <div class="admin-form-footer">
                    <button type="button" class="btn btn-secondary" onclick="window.location.href='@Url.Action("ListadoReservas", "Reserva")'">
                        <span><i class="fas fa-times"></i> Cancelar</span>
                    </button>
                    <button type="submit" class="btn btn-primary btn-3d">
                        <span><i class="fas fa-check"></i> Guardar Cambios</span>
                    </button>
                </div>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script src="~/js/reserva.js"></script>
    <script>
        initHorariosDinamicos(
            'inputFecha',
            'selectHora',
            'aviso-cerrado',
            '@Model.Hora.ToString(@"hh\:mm\:ss")'
        );
    </script>
}