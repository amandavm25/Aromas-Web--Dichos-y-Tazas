@model AromasWeb.Abstracciones.ModeloUI.Reserva

@{
    ViewBag.Title = "Registrar Reserva";
}

<!-- Hero Section -->
<section class="hero" style="min-height: 40vh; padding: 8rem 0 4rem;">
    <div class="hero-bg-overlay"></div>
    <div class="hero-leaves"></div>
    <div class="container hero-container" style="display: block;">
        <div class="hero-content" data-aos="fade-up" style="text-align: center;">
            <span class="hero-badge">
                <i class="fas fa-user-plus"></i>
                Registro de Reserva
            </span>
            <h1 class="hero-title" style="font-size: 3.5rem;">
                Registrar
                <span class="hero-title-accent">Reserva</span>
            </h1>
            <p class="hero-subtitle">
                Registra una nueva reserva para un cliente existente
            </p>
        </div>
    </div>
    <div class="scroll-indicator">
        <div class="mouse"><div class="wheel"></div></div>
    </div>
</section>

<!-- Formulario Section -->
<section class="admin-form-section">
    <div class="container" style="max-width: 80%;">
        @using (Html.BeginForm("RegistrarReservaCliente", "Reserva", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(model => model.IdCliente, new { id = "IdCliente" })
            <input type="hidden" id="NombreCliente" name="NombreCliente" value="" />
            <input type="hidden" id="TelefonoCliente" name="TelefonoCliente" value="" />

            <div class="admin-form-wrapper" data-aos="fade-up">
                @Html.ValidationSummary(false, "Por favor, corrige los siguientes errores:", new { @class = "alert alert-danger" })

                <!-- Buscar Cliente -->
                <div class="admin-form-header">
                    <i class="fas fa-search"></i>
                    <h5>Buscar Cliente</h5>
                </div>

                <div class="form-group">
                    <label><i class="fas fa-id-card"></i> Identificación del Cliente</label>
                    <div style="display: flex; gap: 0.5rem;">
                        <input type="text"
                               id="buscarIdentificacion"
                               class="form-control"
                               placeholder="1-1234-5678"
                               style="flex: 1;" />
                        <button type="button"
                                class="btn btn-primary"
                                onclick="buscarCliente()"
                                style="border-radius: 15px; padding: 0 2rem; white-space: nowrap;">
                            <span><i class="fas fa-search"></i> Buscar</span>
                        </button>
                    </div>
                    <small style="display: block; margin-top: 0.5rem; color: var(--charcoal); opacity: 0.7;">
                        <i class="fas fa-info-circle" style="color: var(--gold);"></i>
                        Ingrese la identificación del cliente y presione Buscar
                    </small>
                </div>

                <!-- Información del Cliente encontrado -->
                <div id="infoCliente" style="display: none; margin: 0 0 1.5rem; padding: 1.5rem; background: var(--cream); border-radius: 20px; border-left: 5px solid var(--green);">
                    <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
                        <div style="width: 50px; height: 50px; background: var(--green); border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: var(--shadow-md);">
                            <i class="fas fa-user-check" style="font-size: 1.5rem; color: white;"></i>
                        </div>
                        <div>
                            <h6 style="color: var(--green); margin: 0 0 0.2rem; font-weight: 700;">
                                <i class="fas fa-check-circle"></i> Cliente Encontrado
                            </h6>
                            <p style="margin: 0; color: var(--charcoal); opacity: 0.7; font-size: 0.9rem;">Los datos se han cargado correctamente</p>
                        </div>
                    </div>
                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1.5rem;">
                        <div>
                            <small style="color: var(--charcoal); opacity: 0.7; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; display: block; margin-bottom: 0.3rem;">
                                <i class="fas fa-user" style="color: var(--olive-green);"></i> Nombre
                            </small>
                            <strong id="clienteNombre" style="color: var(--dark-green);"></strong>
                        </div>
                        <div>
                            <small style="color: var(--charcoal); opacity: 0.7; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; display: block; margin-bottom: 0.3rem;">
                                <i class="fas fa-phone" style="color: var(--olive-green);"></i> Teléfono
                            </small>
                            <strong id="clienteTelefono" style="color: var(--dark-green);"></strong>
                        </div>
                    </div>
                </div>

                <!-- Alerta cliente no encontrado -->
                <div id="clienteNoEncontrado" style="display: none; background: rgba(231,76,60,0.08); border-left: 5px solid var(--red); padding: 1.5rem; border-radius: 15px; margin: 0 0 1.5rem;">
                    <p style="margin: 0; color: #c0392b; font-weight: 600; display: flex; align-items: center; gap: 0.7rem;">
                        <i class="fas fa-exclamation-triangle" style="font-size: 1.2rem;"></i>
                        <span>Cliente no encontrado. Verifique la identificación ingresada.</span>
                    </p>
                </div>

                <!-- Detalles de la Reserva -->
                <div class="admin-form-header">
                    <i class="fas fa-calendar-alt"></i>
                    <h5>Detalles de la Reserva</h5>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label><i class="fas fa-calendar"></i> Fecha</label>
                        @Html.EditorFor(model => model.Fecha, new { htmlAttributes = new { @class = "form-control", type = "date", id = "inputFecha", name = "Fecha", min = DateTime.Now.ToString("yyyy-MM-dd"), required = "required" } })
                        @Html.ValidationMessageFor(model => model.Fecha, "", new { @class = "text-danger" })
                        <small id="aviso-cerrado" style="display:none; color: var(--red); margin-top: 0.4rem;">
                            <i class="fas fa-times-circle"></i> El restaurante no abre ese día (lunes y martes).
                        </small>
                    </div>
                    <div class="form-group">
                        <label><i class="fas fa-clock"></i> Hora</label>
                        <select name="Hora" id="selectHora" class="form-control" required>
                            <option value="">-- Primero selecciona una fecha --</option>
                        </select>
                        @Html.ValidationMessageFor(model => model.Hora, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="form-group">
                    <label><i class="fas fa-users"></i> Cantidad de Personas</label>
                    @Html.EditorFor(model => model.CantidadPersonas, new { htmlAttributes = new { @class = "form-control", type = "number", min = "1", max = "20", placeholder = "1" } })
                    @Html.ValidationMessageFor(model => model.CantidadPersonas, "", new { @class = "text-danger" })
                    <small style="display: block; margin-top: 0.5rem; color: var(--charcoal); opacity: 0.7;">
                        <i class="fas fa-info-circle" style="color: var(--gold);"></i>
                        Máximo 20 personas por reserva
                    </small>
                </div>

                <div class="form-group">
                    <label><i class="fas fa-comment"></i> Observaciones o Notas Especiales</label>
                    <textarea name="Observaciones" class="form-control" rows="4" placeholder="Alergias, preferencias de mesa, celebraciones, etc." style="resize: vertical;"></textarea>
                    <small style="display: block; margin-top: 0.5rem; color: var(--charcoal); opacity: 0.7;">
                        <i class="fas fa-info-circle" style="color: var(--olive-green);"></i>
                        Opcional - Máximo 500 caracteres
                    </small>
                </div>

                <!-- Botones -->
                <div class="admin-form-footer">
                    <button type="button" class="btn btn-secondary" onclick="window.location.href='@Url.Action("ListadoReservas", "Reserva")'">
                        <span><i class="fas fa-times"></i> Cancelar</span>
                    </button>
                    <button type="submit" id="btnRegistrar" class="btn btn-primary btn-3d" disabled>
                        <span><i class="fas fa-save"></i> Registrar Reserva</span>
                    </button>
                </div>
            </div>
        }
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/reserva.js"></script>
    <script>
        function buscarCliente() {
            const identificacion = document.getElementById('buscarIdentificacion').value.trim();
            if (!identificacion) {
                mostrarNotificacion('Por favor ingrese una identificación', 'warning');
                return;
            }
            document.getElementById('infoCliente').style.display = 'none';
            document.getElementById('clienteNoEncontrado').style.display = 'none';

            fetch('@Url.Action("BuscarClientePorIdentificacion", "Reserva")?identificacion=' + encodeURIComponent(identificacion))
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        // Llenar los hidden inputs para que lleguen al POST
                        document.getElementById('IdCliente').value       = data.data.id;
                        document.getElementById('NombreCliente').value   = data.data.nombre;
                        document.getElementById('TelefonoCliente').value = data.data.telefono;

                        // Mostrar visualmente
                        document.getElementById('clienteNombre').textContent   = data.data.nombre;
                        document.getElementById('clienteTelefono').textContent = data.data.telefono;
                        document.getElementById('infoCliente').style.display   = 'block';
                        document.getElementById('btnRegistrar').disabled        = false;
                        mostrarNotificacion('Cliente encontrado correctamente', 'success');
                    } else {
                        document.getElementById('clienteNoEncontrado').style.display = 'block';
                        document.getElementById('btnRegistrar').disabled = true;
                        mostrarNotificacion(data.message, 'error');
                    }
                })
                .catch(() => mostrarNotificacion('Error al buscar el cliente', 'error'));
        }

        document.getElementById('buscarIdentificacion').addEventListener('keypress', function (e) {
            if (e.key === 'Enter') { e.preventDefault(); buscarCliente(); }
        });

        initHorariosDinamicos('inputFecha', 'selectHora', 'aviso-cerrado');
    </script>
}