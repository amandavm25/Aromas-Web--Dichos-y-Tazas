<div class="modal fade admin-modal modal-warning" id="modalCancelarReserva" tabindex="-1" aria-labelledby="modalCancelarReservaLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">

            <!-- Header -->
            <div class="modal-header">
                <h5 class="modal-title" id="modalCancelarReservaLabel">
                    <div class="modal-icon">
                        <i class="fas fa-ban"></i>
                    </div>
                    Cancelar Reserva
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <!-- Body -->
            <div class="modal-body">

                <!-- Aviso -->
                <div class="modal-alert">
                    <div class="modal-alert-icon">
                        <i class="fas fa-exclamation-circle"></i>
                    </div>
                    <div>
                        <h6>Confirmar Cancelación</h6>
                        <p>
                            Al cancelar esta reserva, quedará registrada como <strong>Cancelada</strong>.
                            La reserva permanecerá en el sistema para registro histórico.
                        </p>
                    </div>
                </div>

                <!-- Detalles -->
                <div class="modal-section">
                    <h6 class="modal-section-title">
                        <i class="fas fa-calendar-check"></i> Detalles de la Reserva
                    </h6>

                    <div class="modal-data-grid-2">

                        <div class="modal-data-cell">
                            <label class="modal-data-label">
                                <i class="fas fa-hashtag"></i> Reserva
                            </label>
                            <p id="cancelar-id-display-reserva" class="modal-data-value"></p>
                        </div>

                        <div class="modal-data-cell cell-gold">
                            <label class="modal-data-label">
                                <i class="fas fa-users"></i> Personas
                            </label>
                            <p id="cancelar-personas-reserva" class="modal-data-value value-large"></p>
                        </div>

                        <div class="modal-data-cell">
                            <label class="modal-data-label">
                                <i class="fas fa-user"></i> Cliente
                            </label>
                            <p id="cancelar-cliente-reserva" class="modal-data-value"></p>
                        </div>

                        <div class="modal-data-cell">
                            <label class="modal-data-label">
                                <i class="fas fa-clock"></i> Hora
                            </label>
                            <p id="cancelar-hora-reserva" class="modal-data-value"></p>
                        </div>

                        <div class="modal-data-cell cell-span">
                            <label class="modal-data-label">
                                <i class="fas fa-calendar-alt"></i> Fecha de Reserva
                            </label>
                            <p id="cancelar-fecha-reserva" class="modal-data-value"></p>
                        </div>

                    </div>
                </div>
            </div>

            <!-- Footer -->
            <div class="modal-footer footer-between">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <span><i class="fas fa-arrow-left"></i> Volver</span>
                </button>
                <form id="formCancelarReserva" method="post" action="" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="cancelar-id-reserva" name="IdReserva" />
                    <button type="submit" class="btn btn-primary btn-3d">
                        <span><i class="fas fa-ban"></i> Cancelar Reserva</span>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>