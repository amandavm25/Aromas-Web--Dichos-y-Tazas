<div class="modal fade admin-modal modal-olive" id="modalDetallesCliente" tabindex="-1" aria-labelledby="modalDetallesClienteLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <!-- Header -->
            <div class="modal-header">
                <h5 class="modal-title" id="modalDetallesClienteLabel">
                    <div class="modal-icon">
                        <i class="fas fa-user-circle"></i>
                    </div>
                    Detalles del Cliente
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <!-- Body -->
            <div class="modal-body">

                <!-- Nombre del Cliente -->
                <div class="modal-entity-header entity-block">
                    <h5 id="detalles-nombre-cliente" class="modal-entity-name"></h5>
                </div>

                <!-- ID y Estado en 2 columnas -->
                <div class="modal-data-grid-2">
                    <div class="modal-data-cell">
                        <label class="modal-data-label">
                            <i class="fas fa-hashtag"></i> ID del Cliente
                        </label>
                        <p id="detalles-id-cliente" class="modal-data-value"></p>
                    </div>
                    <div class="modal-data-cell">
                        <label class="modal-data-label">
                            <i class="fas fa-toggle-on"></i> Estado
                        </label>
                        <span id="detalles-estado-badge-cliente" class="badge"
                              style="font-size: 0.95rem; padding: 0.4rem 1.2rem; border-radius: 50px; font-weight: 600; display: inline-block;"></span>
                    </div>
                </div>

                <!-- Datos de contacto -->
                <h6 class="modal-subsection-title">
                    <i class="fas fa-address-card"></i> Información de Contacto
                </h6>
                <div class="modal-data-grid-2">
                    <div class="modal-data-cell">
                        <label class="modal-data-label">
                            <i class="fas fa-id-card"></i> Identificación
                        </label>
                        <p id="detalles-identificacion-cliente" class="modal-data-value"></p>
                    </div>
                    <div class="modal-data-cell">
                        <label class="modal-data-label">
                            <i class="fas fa-phone"></i> Teléfono
                        </label>
                        <p id="detalles-telefono-cliente" class="modal-data-value"></p>
                    </div>
                    <div class="modal-data-cell">
                        <label class="modal-data-label">
                            <i class="fas fa-envelope"></i> Correo Electrónico
                        </label>
                        <p id="detalles-correo-cliente" class="modal-data-value" style="word-break: break-all;"></p>
                    </div>
                    <div class="modal-data-cell">
                        <label class="modal-data-label">
                            <i class="fas fa-calendar-plus"></i> Fecha de Registro
                        </label>
                        <p id="detalles-fecha-cliente" class="modal-data-value"></p>
                    </div>
                </div>

            </div>

            <!-- Footer -->
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <span><i class="fas fa-times"></i> Cerrar</span>
                </button>
            </div>
        </div>
    </div>
</div>