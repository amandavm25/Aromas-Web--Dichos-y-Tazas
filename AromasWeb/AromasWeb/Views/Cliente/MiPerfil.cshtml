@model AromasWeb.Abstracciones.ModeloUI.Cliente

@{
    ViewBag.Title = "Mi Perfil";
}

<!-- Hero Section -->
<section class="hero" style="min-height: 40vh; padding: 8rem 0 4rem;">
    <div class="hero-bg-overlay"></div>
    <div class="hero-leaves"></div>
    <div class="container hero-container" style="display: block;">
        <div class="hero-content" data-aos="fade-up" style="text-align: center;">
            <span class="hero-badge">
                <i class="fas fa-user-circle"></i>
                Mi Cuenta
            </span>
            <h1 class="hero-title" style="font-size: 3.5rem;">
                Mi
                <span class="hero-title-accent">Perfil</span>
            </h1>
            <p class="hero-subtitle">
                Información de tu cuenta
            </p>
        </div>
    </div>
    <div class="scroll-indicator">
        <div class="mouse">
            <div class="wheel"></div>
        </div>
    </div>
</section>

<!-- Content Section -->
<section style="padding: 4rem 0; background: var(--cream);">
    <div class="container" style="max-width: 1200px;">

        <!-- Tarjeta de cabecera del perfil -->
        <div class="admin-modal" data-aos="fade-up" style="margin-bottom: 3rem;">
            <div class="modal-entity-header">

                <!-- Avatar -->
                <div class="modal-entity-avatar">
                    <i class="fas fa-user"></i>
                </div>

                <!-- Nombre y datos rápidos -->
                <div style="flex: 1;">
                    <h4 class="modal-entity-name">@Model.Nombre @Model.Apellidos</h4>
                    <p class="modal-entity-sub">
                        <i class="fas fa-envelope" style="color: var(--olive-green); margin-right: 0.4rem;"></i>@Model.Correo
                    </p>
                    <div class="modal-entity-meta">
                        <div class="modal-entity-meta-item">
                            <small><i class="fas fa-calendar-plus"></i> Miembro Desde</small>
                            <p>@Model.FechaRegistroFormateada</p>
                        </div>
                        <div class="modal-entity-meta-item">
                            <small><i class="fas fa-calendar-check"></i> Última Reserva</small>
                            <p>@Model.UltimaReservaFormateada</p>
                        </div>
                    </div>
                </div>

                <!-- Botón editar -->
                <div>
                    <button type="button" class="btn btn-primary btn-3d"
                            onclick="window.location.href='@Url.Action("EditarPerfil", "Cliente")'">
                        <span><i class="fas fa-edit"></i> Editar Perfil</span>
                    </button>
                </div>

            </div>
        </div>

        <!-- Sección de Información Personal -->
        <div class="admin-table-container admin-modal" style="margin-bottom: 3rem;" data-aos="fade-up">

            <!-- Header -->
            <div class="admin-form-header">
                <i class="fas fa-user"></i>
                <h5>Información Personal</h5>
            </div>

            <!-- Grid de datos -->
            <div style="padding: 2.5rem; background: var(--light-cream); border-radius: 0 0 20px 20px;">
                <div class="modal-data-grid-2">

                    <div class="modal-data-cell" style="background: var(--white);">
                        <label class="modal-data-label">
                            <i class="fas fa-user"></i> Nombre Completo
                        </label>
                        <p class="modal-data-value">@Model.Nombre @Model.Apellidos</p>
                    </div>

                    <div class="modal-data-cell" style="background: var(--white);">
                        <label class="modal-data-label">
                            <i class="fas fa-id-card"></i> Identificación
                        </label>
                        <p class="modal-data-value">@Model.Identificacion</p>
                    </div>

                    <div class="modal-data-cell" style="background: var(--white);">
                        <label class="modal-data-label">
                            <i class="fas fa-envelope"></i> Correo Electrónico
                        </label>
                        <p class="modal-data-value">@Model.Correo</p>
                    </div>

                    <div class="modal-data-cell" style="background: var(--white);">
                        <label class="modal-data-label">
                            <i class="fas fa-phone"></i> Teléfono
                        </label>
                        <p class="modal-data-value">@Model.Telefono</p>
                    </div>

                    <div class="modal-data-cell" style="background: var(--white);">
                        <label class="modal-data-label">
                            <i class="fas fa-calendar-plus"></i> Fecha de Registro
                        </label>
                        <p class="modal-data-value">@Model.FechaRegistroFormateada</p>
                    </div>

                    <div class="modal-data-cell" style="background: var(--white);">
                        <label class="modal-data-label">
                            <i class="fas fa-calendar-check"></i> Última Reserva
                        </label>
                        <p class="modal-data-value">@Model.UltimaReservaFormateada</p>
                    </div>

                </div>

                <!-- Nota al pie -->
                <div class="modal-note">
                    <i class="fas fa-info-circle"></i>
                    Para actualizar tu información personal, utiliza el botón <strong>Editar Perfil</strong> en la parte superior.
                </div>
            </div>

        </div>

    </div>
</section>

@section Scripts {
    <script src="~/js/cliente.js"></script>
}